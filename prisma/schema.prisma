generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GeneratedApp {
  id        String   @id @default(nanoid(5))
  model     String
  prompt    String
  code      String
  createdAt DateTime @default(now())

  @@index([id])
}

model Chat {
  id                    String                 @id @default(nanoid(16))
  model                 String
  quality               String
  prompt                String
  title                 String
  llamaCoderVersion     String                 @default("v2")
  shadcn                Boolean
  plan                  String?
  appSpec               Json?
  hasCode               Boolean                @default(false)
  generationStatus      String                 @default("idle")
  generationStartedAt   DateTime?
  sourceMessageId       String?
  sourceChatId          String?
  referrerUserId        String?
  createdAt             DateTime               @default(now())
  userId                String?
  user                  User?                  @relation(fields: [userId], references: [id])
  messages              Message[]
  projectIntegrations   ProjectIntegration[]
  integrationOperations IntegrationOperation[]
  generationRuns        GenerationRun[]
  runtimeVerifications  RuntimeVerification[]
  galleryPublication    GalleryPublication?

  @@index([createdAt])
  @@index([userId])
  @@index([generationStatus])
  @@index([sourceMessageId])
  @@index([sourceChatId])
  @@index([referrerUserId])
}

model Message {
  id                   String                @id @default(nanoid(16))
  role                 String
  content              String
  files                Json?
  followUpPrompts      Json?
  chatId               String
  position             Int
  changeSummary        String?
  versionKind          String?
  versionLabel         String?
  isBookmarked         Boolean               @default(false)
  createdAt            DateTime              @default(now())
  chat                 Chat                  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  generationRuns       GenerationRun[]
  runtimeVerifications RuntimeVerification[]
  galleryPublication   GalleryPublication?

  @@index([chatId])
  @@index([chatId, createdAt])
}

model ExportArtifact {
  id        String   @id @default(nanoid(16))
  messageId String
  chatId    String
  userId    String?
  appTitle  String
  status    String
  fileCount Int
  manifest  Json
  report    Json
  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([chatId])
  @@index([userId])
  @@index([createdAt])
}

model ShareEvent {
  id             String   @id @default(nanoid(16))
  messageId      String
  chatId         String
  eventType      String
  visitorId      String?
  userId         String?
  referrerUserId String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([messageId])
  @@index([chatId])
  @@index([eventType])
  @@index([visitorId])
  @@index([userId])
  @@index([referrerUserId])
  @@index([createdAt])
}

model User {
  id                     String                  @id
  name                   String?
  email                  String                  @unique
  emailVerified          Boolean                 @default(false)
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  credits                Int                     @default(0)
  chats                  Chat[]
  creditHistory          CreditHistory[]
  creditGrants           CreditGrant[]
  subscription           Subscription?
  accounts               Account[]
  sessions               Session[]
  integrationConnections IntegrationConnection[]
  integrationAuditEvents IntegrationAuditEvent[]
  integrationOperations  IntegrationOperation[]
  generationRuns         GenerationRun[]
  runtimeVerifications   RuntimeVerification[]
  galleryPublications    GalleryPublication[]

  @@map("user")
}

model GalleryPublication {
  id            String    @id @default(nanoid(16))
  slug          String    @unique
  chatId        String    @unique
  messageId     String    @unique
  userId        String
  title         String
  description   String
  allowRemixes  Boolean   @default(false)
  isPublished   Boolean   @default(true)
  publishedAt   DateTime  @default(now())
  unpublishedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  chat          Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished, publishedAt])
  @@index([userId, isPublished])
  @@index([allowRemixes, isPublished])
}

model GenerationRun {
  id                 String    @id @default(nanoid(16))
  userId             String
  chatId             String
  messageId          String
  assistantMessageId String?
  status             String    @default("running")
  phase              String    @default("preparing")
  label              String    @default("Preparing your project")
  partialText        String    @default("")
  creditHoldId       String?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  completedAt        DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat               Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message            Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([userId, status])
  @@index([messageId, createdAt])
}

model RuntimeVerification {
  id        String   @id @default(nanoid(16))
  userId    String
  chatId    String
  messageId String
  status    String
  report    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([chatId, createdAt])
  @@index([userId, createdAt])
}

model IntegrationConnection {
  id                String                  @id @default(nanoid(16))
  userId            String
  providerId        String
  displayName       String
  authType          String
  status            String
  scopes            String[]                @default([])
  metadata          Json?
  lastHealthStatus  String?
  lastHealthMessage String?
  lastHealthCheckAt DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials       IntegrationCredential[]
  projectBindings   ProjectIntegration[]
  auditEvents       IntegrationAuditEvent[]
  operations        IntegrationOperation[]

  @@index([userId, providerId])
  @@index([userId, status])
}

model IntegrationCredential {
  id           String                @id @default(nanoid(16))
  connectionId String
  kind         String
  ciphertext   String
  iv           String
  authTag      String
  keyVersion   Int                   @default(1)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, kind])
  @@index([connectionId])
}

model ProjectIntegration {
  id           String                  @id @default(nanoid(16))
  chatId       String
  connectionId String
  providerId   String
  environment  String
  status       String
  config       Json?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  chat         Chat                    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  connection   IntegrationConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  auditEvents  IntegrationAuditEvent[]
  operations   IntegrationOperation[]

  @@unique([chatId, providerId, environment])
  @@index([chatId, environment])
  @@index([connectionId])
}

model IntegrationOperation {
  id                   String                @id @default(nanoid(16))
  userId               String
  chatId               String
  connectionId         String
  projectIntegrationId String
  providerId           String
  kind                 String
  status               String
  externalId           String?
  url                  String?
  commitSha            String?
  errorMessage         String?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  completedAt          DateTime?
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat                 Chat                  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  projectIntegration   ProjectIntegration    @relation(fields: [projectIntegrationId], references: [id], onDelete: Cascade)
  connection           IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([projectIntegrationId, createdAt])
  @@index([connectionId, createdAt])
  @@index([userId, createdAt])
  @@index([providerId, status])
}

model IntegrationWebhookDelivery {
  id          String   @id @default(nanoid(16))
  providerId  String
  deliveryId  String
  event       String
  payloadHash String
  createdAt   DateTime @default(now())

  @@unique([providerId, deliveryId])
  @@index([providerId, createdAt])
}

model IntegrationAuditEvent {
  id                   String                 @id @default(nanoid(16))
  userId               String
  providerId           String
  action               String
  environment          String?
  connectionId         String?
  projectIntegrationId String?
  metadata             Json?
  createdAt            DateTime               @default(now())
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection           IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  projectIntegration   ProjectIntegration?    @relation(fields: [projectIntegrationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([connectionId, createdAt])
  @@index([projectIntegrationId, createdAt])
}

model Subscription {
  id                   String   @id @default(nanoid(16))
  userId               String   @unique
  stripeCustomerId     String   @unique
  stripePriceId        String
  stripeSubscriptionId String?  @unique
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tier                 String   @default("pro")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model CreditHistory {
  id          String   @id @default(nanoid(16))
  userId      String
  amount      Int
  type        String
  description String?
  chatId      String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model CreditGrant {
  id                      String    @id @default(nanoid(16))
  userId                  String
  amount                  Int
  remainingAmount         Int       @default(0)
  type                    String
  description             String?
  dedupeKey               String    @unique
  stripeEventId           String?
  stripeCheckoutSessionId String?
  stripeInvoiceId         String?
  stripeSubscriptionId    String?
  expiresAt               DateTime?
  grossRevenueUsd         Float?
  netRevenueUsd           Float?
  unitRevenueUsd          Float?
  createdAt               DateTime  @default(now())
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type, remainingAmount])
  @@index([expiresAt])
  @@index([stripeEventId])
  @@index([stripeCheckoutSessionId])
  @@index([stripeInvoiceId])
  @@index([stripeSubscriptionId])
}

model CreditHold {
  id                       String   @id @default(nanoid(16))
  userId                   String
  chatId                   String?
  modelId                  String
  amountHeld               Int
  amountCaptured           Int      @default(0)
  status                   String
  reason                   String?
  phase                    String?
  allocations              Json
  providerCostUsd          Float    @default(0)
  upstreamInferenceCostUsd Float    @default(0)
  inputTokens              Int      @default(0)
  outputTokens             Int      @default(0)
  reasoningTokens          Int      @default(0)
  totalTokens              Int      @default(0)
  provider                 String?
  providerRequestId        String?
  expiresAt                DateTime
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([userId, status])
  @@index([chatId, status])
  @@index([expiresAt])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

model AnonymousUsage {
  id              String   @id @default(nanoid(16))
  ipHash          String
  fingerprintHash String?
  generationsUsed Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ipHash, fingerprintHash])
  @@index([createdAt])
}

model GenerationLog {
  id                       String   @id @default(nanoid(16))
  userId                   String?
  modelId                  String
  creditsUsed              Int
  estimatedCredits         Int?
  actualCredits            Int?
  refundedCredits          Int      @default(0)
  tokensUsed               Int?
  inputTokens              Int?
  outputTokens             Int?
  generationSize           String?
  estimatedModelCostUsd    Float?
  riskAdjustedModelCostUsd Float?
  actualModelCostUsd       Float?
  upstreamInferenceCostUsd Float?
  reasoningTokens          Int?
  provider                 String?
  estimatedRevenueUsd      Float?
  estimatedGrossMarginUsd  Float?
  reason                   String?
  phase                    String?
  status                   String
  chatId                   String?
  messageId                String?
  createdAt                DateTime @default(now())

  @@index([userId, createdAt])
  @@index([modelId])
  @@index([createdAt])
  @@index([chatId, createdAt])
  @@index([messageId])
}

model AiRequestLog {
  id                          String    @id @default(nanoid(16))
  userId                      String?
  chatId                      String?
  messageId                   String?
  creditHoldId                String?
  modelId                     String
  requestKind                 String
  quality                     String
  reasoningEnabled            Boolean
  reasoningMandatory          Boolean
  reasoningEffort             String
  timeToFirstByteMs           Int?
  timeToFirstReasoningDeltaMs Int?
  timeToFirstTextDeltaMs      Int?
  inputTokens                 Int?
  outputTokens                Int?
  reasoningTokens             Int?
  totalTokens                 Int?
  cachedInputTokens           Int?
  provider                    String?
  providerRequestId           String?
  providerCostUsd             Float?
  upstreamInferenceCostUsd    Float?
  finishReason                String?
  status                      String
  errorMessage                String?
  startedAt                   DateTime
  completedAt                 DateTime?
  createdAt                   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([chatId, createdAt])
  @@index([modelId, createdAt])
  @@index([creditHoldId])
  @@map("AIRequestLog")
}

model ApiRateLimitBucket {
  id          String   @id
  userId      String
  operation   String
  count       Int      @default(1)
  windowStart DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, operation, windowStart])
  @@index([expiresAt])
}

model OperationalIncident {
  id           String    @id @default(nanoid(16))
  name         String
  level        String
  operation    String?
  status       String?
  userId       String?
  errorName    String?
  errorMessage String?
  metadata     Json?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([level, createdAt])
  @@index([name, createdAt])
  @@index([resolvedAt, createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
