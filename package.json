{
  "name": "squid-agent",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "postinstall": "fumadocs-mdx && prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "credits:grant": "tsx scripts/grant-credits.ts",
    "db:deploy": "prisma migrate deploy",
    "start": "next start",
    "lint": "eslint . && tsc --noEmit --noUnusedLocals",
    "typecheck": "tsc --noEmit",
    "validate:schema": "prisma validate",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:launch": "RUN_LAUNCH_E2E=1 playwright test tests/e2e/launch-flow.spec.ts --workers=1",
    "test:quick": "pnpm test:unit",
    "ship:quick": "pnpm validate:schema && pnpm typecheck && pnpm lint && pnpm test:unit",
    "ship:full": "pnpm ship:quick && pnpm test:e2e",
    "ship:release": "pnpm ship:quick && pnpm test:e2e --workers=1 && pnpm test:e2e:launch && pnpm exec next build",
    "ship:commit": "git diff --cached --stat",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.prisma": [
      "prisma format"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@aws-sdk/s3-request-presigner": "^3.1088.0",
    "@browserbasehq/stagehand": "^3.7.0",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@codesandbox/sandpack-themes": "^2.0.21",
    "@conform-to/zod": "^1.19.4",
    "@fontsource/instrument-serif": "^5.3.0",
    "@fontsource/inter": "^5.3.0",
    "@headlessui/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@neondatabase/serverless": "^1.0.1",
    "@openrouter/ai-sdk-provider": "2.10.0",
    "@prisma/adapter-neon": "6.5.0",
    "@prisma/client": "6.5.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.11",
