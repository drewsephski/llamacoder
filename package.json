    "clsx": "^2.1.1",
    "dedent": "^1.6.0",
    "framer-motion": "^11.18.0",
    "fumadocs-core": "^16.11.2",
    "fumadocs-mdx": "^14.3.2",
    "hls.js": "^1.6.16",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-plausible": "^3.12.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "resend": "^6.12.2",
    "shaders": "^3.0.440",
    "shiki": "^3.23.0",
