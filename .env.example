# Required API keys
TOGETHER_API_KEY=your_together_api_key
CSB_API_KEY=your_codesandbox_api_key

# Database (Neon)
DATABASE_URL=your_neon_database_url

# Optional, if you want observability
HELICONE_API_KEY=your_helicone_key

# Optional, if you want to upload code to S3
S3_UPLOAD_REGION=us-east-1
S3_UPLOAD_BUCKET=your-s3-bucket
S3_UPLOAD_SECRET=your-s3-secret
S3_UPLOAD_KEY=your-s3-key

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_key

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Subscription Price IDs (from Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_1TQySsRZE8Whwvf0U4nEsJrt           # $9/month - 100 credits
STRIPE_PRO_PLUS_PRICE_ID=price_1TQyStRZE8Whwvf0mciJwsjS      # $29/month - 500 credits

# Credit Pack Price IDs (from Stripe Dashboard)
STRIPE_CREDITS_10_PRICE_ID=price_1TQyStRZE8Whwvf0ofuH4dwB    # $5 - 10 credits
STRIPE_CREDITS_25_PRICE_ID=price_1TQyStRZE8Whwvf0Vwt9tbnK   # $10 - 25 credits
STRIPE_CREDITS_60_PRICE_ID=price_1TQyStRZE8Whwvf0YJb0BFnI   # $20 - 60 credits

# Legacy fallback (optional)
# STRIPE_PRICE_ID=price_xxx  # Deprecated: use STRIPE_PRO_PRICE_ID instead

# Resend (for emails)
RESEND_API_KEY=your_resend_api_key

# Browserbase Configuration (for URL-to-Code feature)
# Get your API key and Project ID from https://browserbase.com/settings
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id
