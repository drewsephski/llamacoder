# Required API keys
CSB_API_KEY=your_codesandbox_api_key

# Database (Neon)
DATABASE_URL=your_neon_database_url

# Integration credential vault (32 random bytes encoded as base64)
# Generate with: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=your_32_byte_base64_key
INTEGRATION_OAUTH_STATE_SECRET=your_second_32_byte_base64_key

# GitHub App (preferred for repository publishing)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_SLUG=your_github_app_slug
# PEM value may use literal newlines or escaped \\n sequences
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Legacy GitHub OAuth App fallback
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

# Vercel Integration
VERCEL_INTEGRATION_CLIENT_ID=your_vercel_integration_client_id
VERCEL_INTEGRATION_CLIENT_SECRET=your_vercel_integration_client_secret
VERCEL_INTEGRATION_SLUG=your_vercel_integration_slug

# Supabase OAuth
SUPABASE_OAUTH_CLIENT_ID=your_supabase_oauth_client_id
SUPABASE_OAUTH_CLIENT_SECRET=your_supabase_oauth_client_secret

# Optional, if you want observability
HELICONE_API_KEY=your_helicone_key

# Optional, if you want to upload code to S3
S3_UPLOAD_REGION=us-east-1
S3_UPLOAD_BUCKET=your-s3-bucket
S3_UPLOAD_SECRET=your-s3-secret
S3_UPLOAD_KEY=your-s3-key

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_VISION_MODEL=google/gemini-3-flash-preview

# Exa Contents API (reads URLs typed directly into chat)
EXA_API_KEY=your_exa_api_key

# Better Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Subscription Price IDs (from Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_squid_pro_monthly                  # $9/month - 100 credits
STRIPE_PRO_PLUS_PRICE_ID=price_squid_pro_plus_monthly        # $29/month - 500 credits

# Credit Pack Price IDs (from Stripe Dashboard)
STRIPE_CREDITS_10_PRICE_ID=price_squid_credits_10            # $5 - 10 credits
STRIPE_CREDITS_25_PRICE_ID=price_squid_credits_25            # $10 - 25 credits
STRIPE_CREDITS_60_PRICE_ID=price_squid_credits_60            # $20 - 60 credits

# Resend (for emails)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="Squid Agent <hello@your-domain.example>"

# Cloudflare Turnstile (required in production for email/password signup)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Production operations
# Accepts JSON POSTs; use a Slack/Discord/PagerDuty relay or your alert intake.
OPERATIONAL_ALERT_WEBHOOK_URL=https://alerts.example.com/squid
# Vercel Cron sends CRON_SECRET. SYNTHETIC_MONITOR_SECRET also permits manual checks.
CRON_SECRET=replace_with_at_least_32_random_characters
SYNTHETIC_MONITOR_SECRET=replace_with_a_different_32_character_secret
SYNTHETIC_MONITOR_MODEL=google/gemini-2.5-flash-lite
GENERATION_LATENCY_ALERT_MS=120000

# Incident controls (comma-separated values; redeploy after changing Vercel env)
GENERATION_KILL_SWITCH=0
DISABLED_PROVIDERS=
DISABLED_MODELS=

# Browserbase Configuration (for URL-to-Code feature)
# Get your API key and Project ID from https://browserbase.com/settings
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_browserbase_project_id
